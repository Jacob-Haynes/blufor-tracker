# Upstream TAK server configuration (optional)
# Copy to upstream.env and uncomment to enable upstream relay.
# The bridge will forward all CoT events to this server and relay
# downstream events back to local ATAK clients via OpenTAKServer.
#
# Without this file, the bridge operates fully offline.

#UPSTREAM_HOST=tak.example.com
#UPSTREAM_PORT=8089
#UPSTREAM_TLS=1
#UPSTREAM_CAFILE=/opt/blufor-tracker/certs/ca.pem
#UPSTREAM_CERTFILE=/opt/blufor-tracker/certs/client.pem
